<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.ram.libraryeqipmentmanagement">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"/>
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".LibraryEquipmentApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LibraryEquipmentManagement"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="31">
        
        <activity
            android:name=".SplashScreenActivity"
            android:exported="true"
            android:theme="@style/Theme.MaterialComponents.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.LibraryEquipmentManagement" />

        <activity
            android:name=".GoogleSignInActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true">
        </activity>

        <activity
            android:name=".LibraryActivity"
            android:exported="false"
            android:theme="@style/Theme.LibraryEquipmentManagement" />

        <activity
            android:name=".LibraryStructureActivity"
            android:exported="false" />

        <activity
            android:name=".EquipmentActivity"
            android:exported="false"
            android:theme="@style/Theme.LibraryEquipmentManagement" />

        <activity
            android:name=".GridActivity"
            android:exported="false" />

        <activity
            android:name=".EquipmentGridActivity"
            android:exported="false" />

        <activity
            android:name=".AccountActivity"
            android:exported="false"
            android:theme="@style/Theme.LibraryEquipmentManagement" />

        <activity
            android:name=".DashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.LibraryEquipmentManagement" />

        <activity
            android:name=".DepartmentActivity"
            android:exported="false"
            android:theme="@style/Theme.LibraryEquipmentManagement" />

        <activity
            android:name=".RequestedQueriesActivity"
            android:exported="false"
            android:theme="@style/Theme.LibraryEquipmentManagement"/>

        <activity
            android:name=".AdminRequestActivity"
            android:exported="false"
            android:label="Admin Requests" />

        <activity
            android:name=".CellActivity"
            android:exported="true" />

        <activity
            android:name=".OpenQueriesActivity"
            android:exported="false"
            android:label="Open Queries"
            android:parentActivityName=".AdminDashboardActivity" />

        <activity
            android:name=".ClosedQueriesActivity"
            android:exported="false"
            android:label="Closed Queries"
            android:parentActivityName=".DashboardActivity" />

        <!-- Add Google Play Services Version -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <!-- Add App Check Debug Provider -->
        <meta-data
            android:name="firebase_app_check_debug_token"
            android:value="true" />

        <!-- Firebase App Check Debug Provider -->
        <meta-data
            android:name="firebase_appcheck_debug_token"
            android:value="REPLACE_WITH_YOUR_DEBUG_TOKEN"
            tools:replace="android:value" />
    </application>

</manifest>